# ─────────────────────────────────────────────────────────────────────────────
# ColdReach — Environment Variables
# Copy to .env and fill in values you need.
# Everything has a safe default; you only need to change what you use.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ColdReach
DEBUG=false

# ── Sign in with Google (optional) ────────────────────────────────────────────
# OAuth 2.0 Web client ID from console.cloud.google.com. Leave empty to disable
# the Google button (email/password login still works). The SAME value must go in
# frontend/.env as VITE_GOOGLE_CLIENT_ID. See SETUP.md for the 3-minute walkthrough.
GOOGLE_CLIENT_ID=

# ── Database (SQLite default — change for Postgres in production) ─────────────
DATABASE_URL=sqlite:///./data/coldreach.db
# DATABASE_URL=postgresql://user:pass@localhost/coldreach

# ── LLM ───────────────────────────────────────────────────────────────────────
# auto = tries Ollama first, falls back to Groq
# Force: ollama | groq | openai | openrouter | anthropic
LLM_PROVIDER=auto
LLM_MODEL=           # leave empty to use provider default

# Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434
# Run model: ollama pull llama3.1

# Groq (cloud free tier — get key at console.groq.com)
# LLM_API_KEY=gsk_...

# OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...

# OpenRouter (100+ models)
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_MODEL=mistralai/mistral-7b-instruct

# ── Optional enrichment ───────────────────────────────────────────────────────
# Hunter.io domain search (25 free/month at hunter.io)
# HUNTER_API_KEY=

# GitHub token (60 → 5,000 req/hr, get at github.com/settings/tokens)
# GITHUB_TOKEN=

# ── CORS (add your frontend URL) ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
