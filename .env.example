# ─────────────────────────────────────────────────────────────────────────────
# ColdReach — Environment Variables
# Copy to .env and fill in values you need.
# Everything has a safe default; you only need to change what you use.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ColdReach
DEBUG=false

# ── Encryption key (required on cloud hosts) ──────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty for local dev — key is auto-created at data/.secret_key instead.
SECRET_KEY=

# ── Sign in with Google (optional) ────────────────────────────────────────────
# OAuth 2.0 Web client ID from console.cloud.google.com. Leave empty to disable
# the Google button (email/password login still works). The SAME value must go in
# frontend/.env as VITE_GOOGLE_CLIENT_ID. See SETUP.md for the 3-minute walkthrough.
GOOGLE_CLIENT_ID=

# ── Database (SQLite default — change for Postgres in production) ─────────────
DATABASE_URL=sqlite:///./data/coldreach.db
# DATABASE_URL=postgresql://user:pass@localhost/coldreach

# ── LLM ───────────────────────────────────────────────────────────────────────
# auto = tries Ollama first, falls back to Groq
# Force: ollama | groq | openai | openrouter | anthropic
LLM_PROVIDER=auto
LLM_MODEL=           # leave empty to use provider default

# Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434
# Run model: ollama pull llama3.1

# Groq (cloud free tier — get key at console.groq.com)
# LLM_API_KEY=gsk_...

# OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...

# OpenRouter (100+ models)
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_MODEL=mistralai/mistral-7b-instruct

# ── Optional enrichment — the hunt works fully WITHOUT any of these ────────────
# Named people (founders/HR/engineers) are found by pure scraping: their email
# printed on the company's own /team & /about pages, YC founder names, and HN
# self-introductions. Email-pattern learning falls back to an UNAUTHENTICATED
# GitHub scan. These keys only ADD signal; nothing below is required.
#
# Hunter.io (free tier: 25 domain searches/month) — extra named-people
# enrichment with real titles. Off by default; the scraping paths cover the
# common case without it.
# HUNTER_API_KEY=

# GitHub token (fine-grained, no scopes needed — github.com/settings/tokens).
# Upgrades pattern learning from the keyless 60-req/hr org scan to the precise
# authenticated commit search, and raises limits 60 → 5,000/hr. Optional.
# GITHUB_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS_ORIGINS: exact-match allowlist for fixed origins — local dev, and any
# custom domain you point at the deployed frontend. Comma-separate multiple.
CORS_ORIGINS=http://localhost:5173

# CORS_ORIGIN_REGEX: catches every URL your Vercel FRONTEND project can be
# served from. Vercel gives a project stable aliases (my-app.vercel.app,
# my-app-<team>.vercel.app, my-app-git-<branch>-<team>.vercel.app) PLUS a
# brand-new unique per-deployment URL on every single deploy — a static list
# in CORS_ORIGINS can never keep up with that last one, and a blocked CORS
# request looks IDENTICAL to "server unreachable" in the browser (no distinct
# error — this bit us in production: one deployment alias worked, two others
# for the exact same frontend project got silently rejected). Set this to
# match your frontend project's Vercel name. Leave empty to disable.
CORS_ORIGIN_REGEX=^https://YOUR-FRONTEND-PROJECT-NAME(-[a-z0-9]+)*\.vercel\.app$
