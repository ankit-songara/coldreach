# ─────────────────────────────────────────────────────────────────────────────
# ColdReach frontend — build-time environment variables
# Copy to .env (Vite only exposes vars prefixed with VITE_ to the browser).
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth 2.0 Web client ID for "Sign in with Google".
# MUST match GOOGLE_CLIENT_ID in the backend .env. Leave empty to hide the
# Google button (email/password login still works). Restart `npm run dev` after
# changing this — Vite reads env vars once at startup.
VITE_GOOGLE_CLIENT_ID=
